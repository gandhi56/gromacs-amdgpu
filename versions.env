# versions.env - pinned upstreams for the two forks that clone-sources.sh fetches.
# Bump these deliberately; the whole point is reproducible LLVM+GROMACS builds.

# Clean upstream LLVM baseline (no custom GROMACS PME/AMDGPU optimizations).
# This is the upstream commit the previous fork was based on; start optimizations
# from scratch on top of this.
LLVM_REMOTE=https://github.com/llvm/llvm-project.git
LLVM_BRANCH=main
LLVM_REF=18ad6a5e073f312d3369803cf607fe9bb66a587d

# GROMACS 2026 HIP feature-enablement fork.
GMX_REMOTE=https://gitlab.com/gromacs/gromacs.git
GMX_BRANCH=4947-hip-feature-enablement
GMX_REF=7f24a2dbf342934c80d65dfedb2aedb84f9a6988
