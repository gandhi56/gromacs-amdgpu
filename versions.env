# versions.env - pinned upstreams for the two forks that clone-sources.sh fetches.
# Bump these deliberately; the whole point is reproducible LLVM+GROMACS builds.

# Custom LLVM with the GROMACS PME/AMDGPU optimizations.
LLVM_REMOTE=https://github.com/gandhi56/llvm-project.git
LLVM_BRANCH=gromacs/pmeSplineAndSpread/combined-optimizations
LLVM_REF=c42008d29dcf1610bd210fa28aabcefa989e41d0

# GROMACS 2026 HIP feature-enablement fork.
GMX_REMOTE=https://gitlab.com/gromacs/gromacs.git
GMX_BRANCH=4947-hip-feature-enablement
GMX_REF=98c2e48b1a77d6f3cc734388ccb59f993f3141df
