#!/usr/bin/env bash
# genmovie — render a PyMOL+ffmpeg movie from a gmxrun trajectory
#
# Usage:
#   genmovie <BUILD__SYSTEM__TAG>           # resolves under $RUNS_DIR
#   genmovie /path/to/run_dir
#   genmovie <run_dir> --max-frames 120 --fps 20 --force
#
# Output: <run_dir>/movie/movie.mp4
#
# Requirements: python3 with pymol-open-source, ffmpeg
set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=/dev/null
. "$HERE/config.sh"

# ── defaults ────────────────────────────────────────────────────────────────
MAX_FRAMES=200
FPS=15
WIDTH=1280
HEIGHT=720
FORCE=0
RUNS_ROOT="$RUNS_DIR"

# ── argument parsing ─────────────────────────────────────────────────────────
RUN_ARG=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --max-frames) MAX_FRAMES="$2"; shift 2 ;;
    --fps)        FPS="$2";        shift 2 ;;
    --width)      WIDTH="$2";      shift 2 ;;
    --height)     HEIGHT="$2";     shift 2 ;;
    --force)      FORCE=1;         shift   ;;
    -*)           echo "Unknown option: $1"; exit 1 ;;
    *)            RUN_ARG="$1";    shift   ;;
  esac
done

[[ -z "$RUN_ARG" ]] && { echo "Usage: genmovie <BUILD__SYSTEM__TAG | run_dir> [options]"; exit 1; }

# ── resolve run directory ────────────────────────────────────────────────────
if [[ -d "$RUN_ARG" ]]; then
  RUN_DIR="$(realpath "$RUN_ARG")"
elif [[ -d "$RUNS_ROOT/$RUN_ARG" ]]; then
  RUN_DIR="$RUNS_ROOT/$RUN_ARG"
else
  echo "error: cannot find run directory for '$RUN_ARG'"
  echo "  tried: $RUN_ARG  and  $RUNS_ROOT/$RUN_ARG"
  exit 1
fi

echo "Run directory: $RUN_DIR"

# ── locate required files ────────────────────────────────────────────────────
TPR="$RUN_DIR/topol.tpr"
GRO="$RUN_DIR/topol.gro"
[[ -f "$TPR" ]] || { echo "error: $TPR not found"; exit 1; }
[[ -f "$GRO" ]] || { echo "error: $GRO not found (run must have completed at least one step)"; exit 1; }

# Prefer XTC over TRR (smaller); fall back to TRR
if   [[ -f "$RUN_DIR/topol.xtc" ]]; then TRAJ="$RUN_DIR/topol.xtc"
elif [[ -f "$RUN_DIR/topol.trr" ]]; then TRAJ="$RUN_DIR/topol.trr"
else  echo "error: no topol.xtc or topol.trr in $RUN_DIR"; exit 1; fi
echo "Trajectory:    $TRAJ"

# ── resolve gmx binary from result.json ──────────────────────────────────────
GMX=""
if [[ -f "$RUN_DIR/result.json" ]]; then
  BUILD=$(python3 -c "import json,sys; print(json.load(open('$RUN_DIR/result.json')).get('build',''))" 2>/dev/null || true)
  [[ -n "$BUILD" && -x "$GMX_INSTALL_ROOT/$BUILD/bin/gmx" ]] && GMX="$GMX_INSTALL_ROOT/$BUILD/bin/gmx"
fi
if [[ -z "$GMX" ]]; then
  GMX=$(command -v gmx 2>/dev/null || true)
fi
[[ -n "$GMX" ]] || { echo "error: cannot find gmx binary (checked result.json and PATH)"; exit 1; }
set +u; source "$(dirname "$GMX")/../bin/GMXRC" 2>/dev/null || true; set -u
echo "GROMACS:       $GMX"

# ── output directory ─────────────────────────────────────────────────────────
MOVIE_DIR="$RUN_DIR/movie"
OUTPUT="$MOVIE_DIR/movie.mp4"
FRAMES_DIR="$MOVIE_DIR/frames"

if [[ -f "$OUTPUT" && "$FORCE" -eq 0 ]]; then
  echo "Movie already exists: $OUTPUT  (use --force to re-render)"
  exit 0
fi

mkdir -p "$FRAMES_DIR"

# ── step 1: count frames and decide skip interval ────────────────────────────
echo ""
echo "── Step 1/3: processing trajectory ────────────────────────────────────"
N_FRAMES_RAW=$("$GMX" check -f "$TRAJ" 2>&1 | awk '/^Coords/{print $2}' || echo 0)
if [[ "$N_FRAMES_RAW" -eq 0 ]]; then
  # fallback: count via check output line
  N_FRAMES_RAW=$("$GMX" check -f "$TRAJ" 2>&1 | grep "Last frame" | awk '{print $3+1}' || echo 1)
fi
echo "Raw frames in trajectory: $N_FRAMES_RAW"

SKIP=1
if [[ "$N_FRAMES_RAW" -gt "$MAX_FRAMES" ]]; then
  SKIP=$(( (N_FRAMES_RAW + MAX_FRAMES - 1) / MAX_FRAMES ))
  echo "Subsampling every $SKIP frames to stay under $MAX_FRAMES frames"
fi

# Generate default index (contains Protein group = 1, System = 0)
"$GMX" make_ndx -f "$TPR" -o "$MOVIE_DIR/index.ndx" <<< "q" 2>/dev/null

# Center on Protein, output System, fix PBC, apply skip
printf "1\n0\n" | "$GMX" trjconv \
  -s "$TPR" \
  -f "$TRAJ" \
  -o "$MOVIE_DIR/traj_movie.xtc" \
  -n "$MOVIE_DIR/index.ndx" \
  -center \
  -pbc mol \
  -skip "$SKIP" \
  2>&1

N_FRAMES=$("$GMX" check -f "$MOVIE_DIR/traj_movie.xtc" 2>&1 | awk '/^Coords/{print $2}')
echo "Frames to render: $N_FRAMES"

# ── step 2: render frames with PyMOL ─────────────────────────────────────────
echo ""
echo "── Step 2/3: rendering $N_FRAMES frames with PyMOL ────────────────────"

python3 - "$GRO" "$MOVIE_DIR/traj_movie.xtc" "$FRAMES_DIR" "$WIDTH" "$HEIGHT" <<'PYEOF'
import sys, os, time
import pymol
from pymol import cmd

gro, xtc, frames_dir, width, height = sys.argv[1], sys.argv[2], sys.argv[3], int(sys.argv[4]), int(sys.argv[5])

pymol.finish_launching(["pymol", "-cq"])

print("Loading structure and trajectory...")
cmd.load(gro, "system")
cmd.load_traj(xtc, "system", interval=1)
n = cmd.count_frames()
print(f"Loaded {cmd.count_atoms()} atoms, {n} frames")

# selections
cmd.select("prot", "polymer")
cmd.select("ions", "not polymer and not resn SOL")

# hide everything, set up protein
cmd.hide("everything")
cmd.show("cartoon", "prot")
cmd.util.cbc("prot")
cmd.set("cartoon_fancy_helices", 1)
cmd.set("cartoon_tube_radius", 0.4)
cmd.set("cartoon_loop_radius", 0.3)

# ions
if cmd.count_atoms("ions") > 0:
    cmd.show("spheres", "ions")
    cmd.set("sphere_scale", 1.0, "ions")
    cmd.color("yellow", "ions")

# scene settings
cmd.bg_color("white")
cmd.set("depth_cue", 0)
cmd.set("ray_shadows", 0)
cmd.set("antialias", 1)
cmd.set("hash_max", 300)

# fixed view from frame 1
cmd.frame(1)
cmd.orient("prot")
cmd.zoom("prot", 8)
view = cmd.get_view()

print(f"Rendering {n} frames to {frames_dir}/")
t0 = time.time()
for i in range(1, n + 1):
    cmd.frame(i)
    # water shell — reselect each frame as positions change
    cmd.select("wat_shell", "resn SOL and name OW within 5 of prot")
    cmd.show("spheres", "wat_shell")
    cmd.color("gray80", "wat_shell")
    cmd.set("sphere_scale", 0.18, "wat_shell")
    cmd.set_view(view)
    cmd.png(os.path.join(frames_dir, f"frame_{i:04d}.png"), width=width, height=height, ray=0, quiet=1)
    if i % 10 == 0 or i == n:
        elapsed = time.time() - t0
        eta = elapsed / i * (n - i)
        print(f"  frame {i:4d}/{n}  ({elapsed:.0f}s elapsed, ~{eta:.0f}s remaining)")

print(f"Rendering done in {time.time()-t0:.0f}s")
cmd.quit()
PYEOF

# ── step 3: assemble movie with ffmpeg ────────────────────────────────────────
echo ""
echo "── Step 3/3: assembling movie with ffmpeg ──────────────────────────────"

ffmpeg -y \
  -framerate "$FPS" \
  -i "$FRAMES_DIR/frame_%04d.png" \
  -c:v libx264 \
  -preset slow \
  -crf 18 \
  -pix_fmt yuv420p \
  -movflags +faststart \
  "$OUTPUT"

echo ""
echo "Movie written to: $OUTPUT"
ls -lh "$OUTPUT"
